TRAEFIK_VERSION=v3.0
TRAEFIK_API_INSECURE=true
TRAEFIK_PROVIDERS_DOCKER=true
TRAEFIK_PROVIDERS_DOCKER_EXPOSEDBYDEFAULT=false
TRAEFIK_ENTRYPOINTS_WEB_ADDRESS=:80
TRAEFIK_PORT_80=80
TRAEFIK_PORT_8080=8080
TRAEFIK_VOLUME_DOCKER_SOCK=/var/run/docker.sock

WHOAMI_IMAGE=traefik/whoami
WHOAMI_TRAEFIK_ENABLE=true
WHOAMI_HOST=whoami.localhost
WHOAMI_ENTRYPOINTS=web
