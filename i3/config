font pango:Hack Nerd Font Mono 15
exec --no-startup-id dunst
exec --no-startup-id unclutter
exec --no-startup-id udiskie &
exec --no-startup-id picom -b
exec --no-startup-id redshift

set $mod Mod4
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+0 workspace number $ws10
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9

bindsym $mod+Ctrl+h move workspace to output left
bindsym $mod+Ctrl+j move workspace to output down 
bindsym $mod+Ctrl+k move workspace to output up
bindsym $mod+Ctrl+l move workspace to output right

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+0 move container to workspace number $ws10
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+BackSpace exec $ROFI_DIR/scripts/power-menu.sh
bindsym $mod+space exec $ROFI_DIR/scripts/launcher.sh

bindsym $mod+Return exec alacritty
bindsym $mod+Shift+f floating toggle
bindsym $mod+Shift+q kill
bindsym $mod+Shift+r restart
bindsym $mod+Shift+t layout toggle split
bindsym $mod+f fullscreen toggle
bindsym $mod+t layout tabbed
bindsym $mod+x exec dunstctl close-all

bindsym XF86AudioLowerVolume exec $I3_DIR/scripts/change_volume.sh down
bindsym XF86AudioMute exec $I3_DIR/scripts/change_volume.sh mute
bindsym XF86AudioPlay exec --no-startup-id playerctl play-pause
bindsym XF86AudioRaiseVolume exec $I3_DIR/scripts/change_volume.sh up
bindsym XF86MonBrightnessDown exec $I3_DIR/scripts/change_brightness.sh down
bindsym XF86MonBrightnessUp exec $I3_DIR/scripts/change_brightness.sh up

workspace_auto_back_and_forth no
focus_follows_mouse no

for_window [window_role="pop-up"] floating enable
for_window [window_role="task_dialog"] floating enable

mode "resize" {
        bindsym h resize shrink width 25 px or 25 ppt
        bindsym j resize grow height 25 px or 25 ppt
        bindsym k resize shrink height 25 px or 25 ppt
        bindsym l resize grow width 25 px or 25 ppt
        bindsym Return mode "default"
        bindsym E1cape mode "default"
}
bindsym $mod+r mode "resize"

set_from_resource $foreground foreground
set_from_resource $background background

set_from_resource $black1  color0
set_from_resource $black2 color8

set_from_resource $red1 color1 
set_from_resource $red2 color9 

set_from_resource $green1 color2 
set_from_resource $green2 color10 

set_from_resource $yellow1 color3 
set_from_resource $yellow2 color11 

set_from_resource $blue1 color4 
set_from_resource $blue2 color12

set_from_resource $magenta1 color5 
set_from_resource $magenta2 color13

set_from_resource $cyan1 color6 
set_from_resource $cyan2 color14

set_from_resource $white1 color7 
set_from_resource $white2 color15

# Format: client.<state> <border> <background> <text> <indicator> <child_border>
client.focused          $background $black2 $white2 $background
client.focused_inactive $background $black1 $black2 $background
client.unfocused        $background $background $black2 $background
client.urgent           $red1 $red1 $white2 $red1 $red1
client.placeholder      $red1 $red1 $white2 $red1 $red1

gaps inner 10
gaps outer 10

for_window [class=".*"] border pixel 3

bar {
    i3bar_command $POLYBAR_DIR/scripts/launch.sh
}

