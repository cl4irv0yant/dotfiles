#!/bin/bash

SERVICE_NAME=$1

if [ "$SERVICE_NAME" == "docker" ]; then
	if systemctl is-active --quiet docker.service; then
		sudo systemctl stop docker.service
		sudo systemctl stop docker.socket
	else
		sudo systemctl start docker.socket
		sudo systemctl start docker.service
	fi
elif [ "$SERVICE_NAME" == "syncthing" ]; then
	if systemctl is-active "syncthing@$(whoami).service"; then
		sudo systemctl stop "syncthing@$(whoami).service"
	else
		sudo systemctl start "syncthing@$(whoami).service"
	fi
	if systemctl is-active --quiet "$SERVICE_NAME"; then
		sudo systemctl stop "$SERVICE_NAME"
	else
		sudo systemctl start "$SERVICE_NAME"
	fi
fi
